<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Project Tasks</title>

    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100">

    <!-- Navbar -->

    <nav class="bg-blue-600 text-white p-4 shadow">

        <div class="max-w-7xl mx-auto flex justify-between items-center">

            <h1 class="text-2xl font-bold">

                Task Management System

            </h1>

            <div class="flex items-center gap-5">

                <span>

                    Welcome,
                    <%= user.name %>

                </span>

                <a
                    href="/dashboard"
                    class="bg-white text-blue-600 px-4 py-2 rounded">

                    Dashboard

                </a>

            </div>

        </div>

    </nav>

    <!-- Main Content -->

    <div class="max-w-6xl mx-auto mt-10">

        <div class="flex justify-between items-center mb-8">

            <h2 class="text-3xl font-bold">

                Project Tasks

            </h2>

            <button
                id="openTaskModal"
                class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded">

                + Add Task

            </button>

        </div>

        <!-- Tasks -->

        <div
            id="tasksContainer"
            class="space-y-5">

        </div>

    </div>

    <!-- Create Task Modal -->

    <div
        id="taskModal"
        class="fixed inset-0 bg-black/50 hidden justify-center items-center">

        <div class="bg-white w-[500px] rounded-lg p-6">

            <h2 class="text-2xl font-bold mb-5">

                Create Task

            </h2>

            <form id="taskForm">

                <input
                    type="text"
                    name="taskName"
                    placeholder="Task Name"
                    class="border w-full p-3 rounded mb-4"
                    required>

                <textarea
                    name="description"
                    placeholder="Task Description"
                    class="border w-full p-3 rounded mb-4"
                    rows="4"
                    required></textarea>

                <select
                    name="completed"
                    class="border w-full p-3 rounded mb-4">

                    <option value="false">

                        Pending

                    </option>

                    <option value="true">

                        Completed

                    </option>

                </select>

                <div class="flex justify-end gap-3">

                    <button
                        type="button"
                        id="closeTaskModal"
                        class="bg-gray-500 hover:bg-gray-600 text-white px-5 py-2 rounded">

                        Cancel

                    </button>

                    <button
                        type="submit"
                        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded">

                        Create Task

                    </button>

                </div>

            </form>

        </div>

    </div>

    <!-- Pass Project ID To JavaScript -->

    <script>

        const projectId = "<%= projectId %>";

    </script>

    <!-- Tasks JS -->

    <script src="/static/js/tasks.js"></script>

</body>

</html>